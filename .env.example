POSTGRES_DB=modaflow
POSTGRES_USER=modaflow
POSTGRES_PASSWORD=modaflow
DATABASE_URL=postgresql+psycopg://modaflow:modaflow@db:5432/modaflow
VITE_API_URL=http://localhost:8000/api
# Chave usada para assinar os tokens de sessão — mude para um valor aleatório longo em produção.
SECRET_KEY=modaflow-dev-secret-change-me-0123456789abcdef
# Palavra-passe inicial dos utilizadores criados pelo seed (alterar após o primeiro acesso).
SEED_USER_PASSWORD=ModaFlow2026!
# Origens permitidas no CORS, separadas por vírgula (acrescente aqui o domínio de produção).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# URL público do backend (usado nos links das fotos carregadas).
PUBLIC_URL=http://localhost:8000
# Opcional: ativa “Ler fotografia” no Shopping. Configure também no Railway.
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-5-mini
